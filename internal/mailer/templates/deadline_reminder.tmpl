                            <p style="margin: 0 0 24px 0; color: #4a5568;">A friendly nudge — {{if eq (len .Bookmarks) 1}}an application in your shortlist closes{{else}}{{len .Bookmarks}} applications in your shortlist close{{end}} in 3 days.</p>
                        </td>
                    </tr>

                    <tr>
                        <td style="padding: 0 40px 24px 40px;">
                            {{range .Bookmarks}}
                            <table border="0" cellpadding="0" cellspacing="0" width="100%" style="margin-bottom: 16px; background-color: #faf5ec; border-radius: 8px; border-left: 3px solid #7d2820;">
