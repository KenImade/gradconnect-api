                                        <p style="margin: 0 0 4px 0; color: #1a202c; font-size: 16px; font-weight: 600;">{{.Title}}</p>
                                        <p style="margin: 0 0 12px 0; color: #4a5568; font-size: 14px;">{{.EmployerName}}</p>
                                        <p style="margin: 0 0 12px 0; color: #718096; font-size: 13px;">Closes {{.Deadline.Format "Mon, 02 Jan 2006"}}</p>
                                        <a href="{{$.FrontendURL}}/opportunities/{{.OpportunitySlug}}"
                                           style="color: #7d2820; font-size: 14px; font-weight: 600; text-decoration: none;">View opportunity →</a>
                                    </td>
                                </tr>
                            </table>
                            {{end}}
                        </td>
                    </tr>

                    <tr>
                        <td style="padding: 8px 40px 40px 40px; text-align: center;">
                            <a href="{{.FrontendURL}}/shortlist"
                               style="background-color: #7d2820; color: #ffffff; padding: 14px 32px; text-decoration: none; border-radius: 6px; font-weight: 600; font-size: 15px; display: inline-block;">
                               Open my shortlist
